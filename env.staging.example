# Staging Environment Variables
# Copier ce fichier en .env.staging et remplir les valeurs

# Database
DB_PASSWORD=staging_password_changez_moi

# API
NEXT_PUBLIC_API_URL=http://[IP-SERVEUR]:4002
CORS_ORIGIN=http://[IP-SERVEUR]:4000

# Application
NODE_ENV=staging
PORT=3002

# Auth basique pour staging (optionnel)
STAGING_AUTH_USER=staging
STAGING_AUTH_PASSWORD=changez_moi

