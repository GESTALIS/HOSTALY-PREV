# Railway Environment Variables
# Copier ce fichier et renommer en .env pour le développement local

# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/hotaly_prev"

# Backend
NODE_ENV=production
PORT=3002
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3002

# Railway specific (sera automatiquement configuré par Railway)
# RAILWAY_PUBLIC_DOMAIN
# RAILWAY_STATIC_URL
